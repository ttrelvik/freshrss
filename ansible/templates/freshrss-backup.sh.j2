#!/usr/bin/env bash
# Ansible managed: Do not edit manually.
set -euo pipefail

BACKUP_DIR="{{ freshrss_backup_dir }}"
DB_USER="{{ postgres_user }}"
DB_NAME="{{ postgres_db }}"
DB_HOST="{{ stack_name }}_db"
DATE=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/freshrss_backup_${DATE}.sql"

# Ensure the backup directory exists
mkdir -p "${BACKUP_DIR}"

echo "Starting FreshRSS database backup..."

# Attempt 1: Network-based pg_dump using a temporary container attached to the overlay network.
# This works on any Swarm manager node regardless of where the DB task is currently scheduled.
if docker run --rm --network="{{ stack_name }}_freshrss-net" \
  -e PGPASSWORD="{{ postgres_password }}" \
  postgres:16 \
  pg_dump -h "${DB_HOST}" -U "${DB_USER}" -d "${DB_NAME}" > "${BACKUP_FILE}"; then
  
  echo "Network-based pg_dump succeeded."
else
  echo "Warning: Network-based backup failed. Attempting local container backup as a fallback..." >&2
  
  # Attempt 2: Fallback to local docker exec if the DB container is hosted on this specific node
  CONTAINER_ID=$(docker ps -q -f name="{{ stack_name }}_db" || true)
  if [ -n "${CONTAINER_ID}" ]; then
    if docker exec -t "${CONTAINER_ID}" pg_dump -U "${DB_USER}" "${DB_NAME}" > "${BACKUP_FILE}"; then
      echo "Local container backup fallback succeeded."
    else
      echo "Error: Local container backup fallback failed." >&2
      rm -f "${BACKUP_FILE}"
      exit 1
    fi
  else
    echo "Error: Database container not found on this host and network backup failed." >&2
    rm -f "${BACKUP_FILE}"
    exit 1
  fi
fi

# Gzip the backup to save space
gzip "${BACKUP_FILE}"

# Keep only the last 7 days of backups
find "${BACKUP_DIR}" -type f -name "freshrss_backup_*.sql.gz" -mtime +7 -delete

echo "Database backup completed successfully: ${BACKUP_FILE}.gz"
